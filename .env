# ======================
# 服务器基础配置
# ======================
PORT=3000
NODE_ENV=development

# ======================
# MongoDB 数据库配置
# ======================
MONGO_URI=mongodb://localhost:27017/ECNU-MCForum

# ======================
# JWT 登录密钥（最重要）
# ======================
JWT_SECRET=你的超级密钥_随便打一串长乱码_绝对不要告诉别人
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d